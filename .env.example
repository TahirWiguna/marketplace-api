# Auth DB
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_password
AUTH_DB_NAME=auth_db

# Marketplace DB
MARKETPLACE_DB_USER=marketplace_user
MARKETPLACE_DB_PASSWORD=marketplace_password
MARKETPLACE_DB_NAME=marketplace_db

# Auth Service DB URL (used inside the container)
AUTH_DATABASE_URL=postgresql+asyncpg://auth_user:auth_password@auth-db:5432/auth_db

# Marketplace Service DB URL (used inside the container)
MARKETPLACE_DATABASE_URL=postgresql+asyncpg://marketplace_user:marketplace_password@marketplace-db:5432/marketplace_db

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Inter-service communication
AUTH_SERVICE_URL=http://auth-service:8000
